#!/usr/bin/env zsh

_log_error() {
   print -u2 -- "mdp: $*"
}

typeset -a _mdp_cleanup_files

_mdp_register_cleanup() {
   local file="$1"
   [[ -n "$file" ]] || return
   _mdp_cleanup_files+=("$file")
}

_mdp_cleanup() {
   local file
   for file in "${_mdp_cleanup_files[@]}"; do
       [[ -n "$file" && -e "$file" ]] && rm -f -- "$file"
   done
}

_mdp_first_heading_title() {
   local file="$1"
   local line title

   while IFS= read -r line || [[ -n "$line" ]]; do
       line="${line%$'\r'}"
       if [[ "$line" =~ '^[[:space:]]{0,3}#{1,6}[[:space:]]+(.+)$' ]]; then
           title="${match[1]}"
           if [[ "$title" =~ '^(.*[^[:space:]])[[:space:]]+#+[[:space:]]*$' ]]; then
               title="${match[1]}"
           fi
           if [[ "$title" =~ '^[[:space:]]*(.*[^[:space:]])[[:space:]]*$' ]]; then
               print -r -- "${match[1]}"
               return 0
           fi
       fi
   done <"$file"

   return 1
}

trap _mdp_cleanup EXIT

source_arg="$1"
source_file=""
source_title=""
clipboard_file=""
stdin_file=""
script_path="$0"
if [[ "$script_path" != */* ]]; then
   script_path=$(whence -p "$0")
fi
if [[ -z "$script_path" || ! -e "$script_path" ]]; then
   _log_error "Unable to resolve mdp script path"
   exit 1
fi
script_dir="${script_path:A:h}"
zush_home="${ZUSH_HOME:-${script_dir:h}}"
pandoc_reader="markdown+lists_without_preceding_blankline"
diagram_filter="${zush_home}/vendor/pandoc-ext/diagram/_extensions/diagram/diagram.lua"
preview_css="${zush_home}/assets/mdp-preview.css"
preview_before_body="${zush_home}/assets/mdp-preview-before-body.html"
preview_after_body="${zush_home}/assets/mdp-preview-after-body.html"
mermaid_bin="${commands[mmdc]:-${zush_home}/scripts/mmdc-wrapper.sh}"

if [[ -n "$source_arg" ]]; then
   if [[ ! -f "$source_arg" ]]; then
       _log_error "Markdown file not found: $source_arg"
       exit 1
   fi
   source_file="$source_arg"
   source_title="${source_file:t:r}"
elif [[ ! -t 0 ]]; then
   stdin_file=$(mktemp /tmp/mdstdin-XXXX.md) || exit 1
   if ! command cat >"$stdin_file"; then
       rm -f "$stdin_file"
       _log_error "Failed to read standard input"
       exit 1
   fi
   source_file="$stdin_file"
   source_title="$(_mdp_first_heading_title "$stdin_file")" || source_title="Standard Input Preview"
   _mdp_register_cleanup "$stdin_file"
else
   if ! command -v kitten >/dev/null 2>&1; then
       _log_error "Kitten clipboard command required when no file is provided"
       exit 1
   fi
   clipboard_file=$(mktemp /tmp/mdclipboard-XXXX.md) || exit 1
   if ! kitten clipboard --get >"$clipboard_file"; then
       rm -f "$clipboard_file"
       _log_error "Failed to read clipboard contents"
       exit 1
   fi
   source_file="$clipboard_file"
   source_title="$(_mdp_first_heading_title "$clipboard_file")" || source_title="Clipboard Preview"
   _mdp_register_cleanup "$clipboard_file"
fi

[[ -n "$source_title" ]] || source_title="${source_file:t:r}"

if [[ ! -f "$diagram_filter" ]]; then
   _log_error "Missing diagram filter: $diagram_filter"
   exit 1
fi

if [[ ! -f "$preview_css" ]]; then
   _log_error "Missing preview CSS: $preview_css"
   exit 1
fi

if [[ ! -f "$preview_before_body" ]]; then
   _log_error "Missing before-body HTML: $preview_before_body"
   exit 1
fi

if [[ ! -f "$preview_after_body" ]]; then
   _log_error "Missing after-body HTML: $preview_after_body"
   exit 1
fi

if [[ ! -x "$mermaid_bin" ]]; then
   _log_error "Mermaid binary is not executable: $mermaid_bin"
   exit 1
fi

preview_file=$(mktemp /tmp/mdpreview-XXXX.html) || exit 1

MERMAID_BIN="$mermaid_bin" pandoc \
    -f "$pandoc_reader" \
    --standalone \
    --embed-resources \
    --css "$preview_css" \
    --lua-filter "$diagram_filter" \
    --include-before-body "$preview_before_body" \
    --include-after-body "$preview_after_body" \
    --metadata title="$source_title" \
    -t html "$source_file" -o "$preview_file"

pandoc_status=$?

if (( pandoc_status != 0 )); then
   exit $pandoc_status
fi

xdg-open "$preview_file"
