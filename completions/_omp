_omp() {
	local curcontext="$curcontext" state line
	typeset -A opt_args
	_arguments -C -s \
		'(-h --help)'{-h,--help}'[Show help]' \
		'(-v --version)'{-v,--version}'[Show version]' \
		'--model[Model to use (fuzzy match  "opus", "gpt-5.2", or "openai/gpt-5.2")]:model:_omp_call models' \
		'--smol[Smol/fast model for lightweight tasks (or PI_SMOL_MODEL env)]:model:_omp_call models' \
		'--slow[Slow/reasoning model for thorough analysis (or PI_SLOW_MODEL env)]:model:_omp_call models' \
		'--plan[Plan model for architectural planning (or PI_PLAN_MODEL env)]:model:_omp_call models' \
		'--provider[Provider to use (legacy; prefer --model)]:file:_files' \
		'--api-key[API key (defaults to env vars)]:file:_files' \
		'--system-prompt[System prompt (default  coding assistant prompt)]:file:_files' \
		'--append-system-prompt[Append text or file contents to the system prompt]:file:_files' \
		'--allow-home[Allow starting in ~ without auto-switching to a temp dir]' \
		'--cwd[Directory to start in (overrides the launch cwd)]:file:_files' \
		'--mode[Output mode  text (default), json, rpc, or rpc-ui]:value:(text json rpc acp rpc-ui)' \
		'*--config[Load an extra config.yml-style overlay for this run (repeatable)]:file:_files' \
		'(-p --print)'{-p,--print}'[Non-interactive mode  process prompt and exit]' \
		'(-c --continue)'{-c,--continue}'[Continue previous session]' \
		'(-r --resume)'{-r,--resume}'[Resume a session (by ID prefix, path, or picker if omitted)]:session:_omp_call sessions' \
		'--session-dir[Directory for session storage and lookup]:dir:_files -/' \
		'--no-session[Don’t save session (ephemeral)]' \
		'--models[Comma-separated model patterns for Ctrl+P cycling]:models:_omp_models_list' \
		'--no-tools[Disable all built-in tools]' \
		'--no-lsp[Disable LSP tools, formatting, and diagnostics]' \
		'--no-pty[Disable PTY-based interactive bash execution]' \
		'--tools[Comma-separated list of tools to enable (default  all)]:value:_omp_tools' \
		'--thinking[Set thinking level  minimal, low, medium, high, xhigh]:value:(minimal low medium high xhigh)' \
		'--hide-thinking[Hide thinking blocks in TUI output (display only, does not disable model thinking)]' \
		'*--hook[Load a hook/extension file (can be used multiple times)]:file:_files' \
		'*'{-e,--extension}'[Load an extension file (can be used multiple times)]:file:_files' \
		'--no-extensions[Disable extension discovery (explicit -e paths still work)]' \
		'--no-skills[Disable skills discovery and loading]' \
		'--skills[Comma-separated glob patterns to filter skills (e.g., git-*,docker)]:file:_files' \
		'--no-rules[Disable rules discovery and loading]' \
		'--export[Export session file to HTML and exit]:file:_files' \
		'--list-recent[List the 10 most recent sessions across all directories and exit]' \
		'--list-models[List available models (with optional fuzzy search)]:file:_files' \
		'--no-title[Disable title auto-generation]' \
		'--auto-approve[Auto-approve all tool calls (skip approval prompts)]' \
		'--approval-mode[Override tools.approvalMode for this session (always-ask|write|yolo)]:value:(always-ask write yolo)' \
		'1: :_omp_commands' \
		'*::arg:->args'
	case $state in
		args)
			case $line[1] in
			acp) _omp_cmd_acp ;;
			agents) _omp_cmd_agents ;;
			auth-broker) _omp_cmd_auth_broker ;;
			auth-gateway) _omp_cmd_auth_gateway ;;
			commit) _omp_cmd_commit ;;
			completions) _omp_cmd_completions ;;
			config) _omp_cmd_config ;;
			dry-balance) _omp_cmd_dry_balance ;;
			gallery) _omp_cmd_gallery ;;
			grep) _omp_cmd_grep ;;
			grievances) _omp_cmd_grievances ;;
			install) _omp_cmd_install ;;
			plugin) _omp_cmd_plugin ;;
			read) _omp_cmd_read ;;
			search|q) _omp_cmd_search ;;
			setup) _omp_cmd_setup ;;
			shell) _omp_cmd_shell ;;
			ssh) _omp_cmd_ssh ;;
			stats) _omp_cmd_stats ;;
			tiny-models) _omp_cmd_tiny_models ;;
			update) _omp_cmd_update ;;
			usage) _omp_cmd_usage ;;
			worktree|wt) _omp_cmd_worktree ;;
			esac
			;;
	esac
}
# Works both ways: autoloaded from $fpath (file named _omp) or eval'd from a
# startup file. When autoloaded, funcstack[1] is _omp and we invoke it; when
# sourced/eval'd we register it with compdef instead.
if [ "$funcstack[1]" = "_omp" ]; then
	_omp "$@"
else
	compdef _omp omp
fi

